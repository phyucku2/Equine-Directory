# PostgreSQL connection used by the crawler to seed listings
DATABASE_URL=postgresql://user:password@localhost:5432/equine_directory

# Google Places API key — required for `--source places` (the recommended,
# authoritative source). Enable "Places API (New)" in Google Cloud.
# GOOGLE_MAPS_API_KEY=

# LLM category grading (optional — heuristic is used if none set).
# Provider fallback order; Gemini primary, Claude on rate-limit/error.
# GRADING_PROVIDERS=gemini,anthropic
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# OPENAI_API_KEY=          # optional third fallback
# GRADING_MODEL=gpt-4o-mini

# Optional: ping the web app to revalidate caches after a batch upsert.
# REVALIDATE_URL=http://localhost:3000/api/revalidate
# REVALIDATE_SECRET=change-me

# Crawl politeness
CRAWL_DELAY_SECONDS=2
CRAWL_MAX_CONCURRENCY=3
